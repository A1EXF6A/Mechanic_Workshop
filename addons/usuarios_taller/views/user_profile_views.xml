<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_taller_form" model="ir.ui.view">
        <field name="name">res.partner.taller.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="before">
                <page name="taller" string="Taller">
                    <group>
                        <field name="cedula"/>
                        <field name="celular"/>
                        <field name="edad"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_taller_partner" model="ir.actions.act_window">
        <field name="name">Clientes Taller</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cedula', '!=', False)]</field>
    </record>

    <menuitem id="menu_taller_partner_root" name="Taller" sequence="10"/>
    <menuitem id="menu_taller_partner" name="Clientes" parent="menu_taller_partner_root" action="action_taller_partner"/>
</odoo>
