<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="usuarios_taller_user_profile_list" model="ir.ui.view">
        <field name="name">usuarios_taller.user_profile.list</field>
        <field name="model">usuarios_taller.user_profile</field>
        <field name="arch" type="xml">
            <list string="Usuarios Taller">
                <field name="cedula"/>
                <field name="nombre"/>
                <field name="apellido"/>
                <field name="email"/>
                <field name="celular"/>
                <field name="edad"/>
            </list>
        </field>
    </record>

    <record id="usuarios_taller_user_profile_form" model="ir.ui.view">
        <field name="name">usuarios_taller.user_profile.form</field>
        <field name="model">usuarios_taller.user_profile</field>
        <field name="arch" type="xml">
            <form string="Usuario Taller">
                <sheet>
                    <group>
                        <group>
                            <field name="cedula"/>
                            <field name="nombre"/>
                            <field name="apellido"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="direccion"/>
                            <field name="celular"/>
                            <field name="edad"/>
                            <field name="password" password="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="usuarios_taller_user_profile_action" model="ir.actions.act_window">
        <field name="name">Usuarios Taller</field>
        <field name="res_model">usuarios_taller.user_profile</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Los menús se han movido a taller_mecanico para estar integrados -->
</odoo>
