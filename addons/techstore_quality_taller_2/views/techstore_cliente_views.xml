<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_techstore_cliente_list" model="ir.ui.view">
        <field name="name">techstore.cliente.list</field>
        <field name="model">techstore.cliente</field>
        <field name="arch" type="xml">
            <list string="Clientes">
                <field name="name"/>
                <field name="cedula"/>
                <field name="email"/>
                <field name="telefono"/>
                <field name="activo"/>
            </list>
        </field>
    </record>

    <record id="view_techstore_cliente_form" model="ir.ui.view">
        <field name="name">techstore.cliente.form</field>
        <field name="model">techstore.cliente</field>
        <field name="arch" type="xml">
            <form string="Cliente">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="cedula"/>
                        <field name="email"/>
                        <field name="telefono"/>
                        <field name="activo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_techstore_cliente" model="ir.actions.act_window">
        <field name="name">Clientes</field>
        <field name="res_model">techstore.cliente</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>