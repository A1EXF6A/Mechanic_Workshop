<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menús en el sitio web -->
    <record id="menu_taller_home" model="website.menu">
        <field name="name">Inicio</field>
        <field name="url">/</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">10</field>
    </record>

    <record id="menu_taller_servicios" model="website.menu">
        <field name="name">Servicios</field>
        <field name="url">/taller/servicios</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">20</field>
    </record>

    <record id="menu_taller_contacto" model="website.menu">
        <field name="name">Contacto</field>
        <field name="url">/taller/contacto</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">30</field>
    </record>

    <record id="menu_taller_cita" model="website.menu">
        <field name="name">Agendar Cita</field>
        <field name="url">/taller/cita</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">40</field>
    </record>

    <record id="menu_taller_productos" model="website.menu">
        <field name="name">Comprar Productos</field>
        <field name="url">/taller/productos</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">50</field>
    </record>

    <record id="menu_taller_carrito" model="website.menu">
        <field name="name">🛒 Carrito</field>
        <field name="url">/taller/carrito</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">60</field>
    </record>

    <record id="menu_taller_login" model="website.menu">
        <field name="name">Ingresar</field>
        <field name="url">/taller/login</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">90</field>
    </record>

    <!-- Inyectar Google Fonts -->
    <template id="taller_custom_head" inherit_id="website.layout" name="Head Personalizado Taller">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Poppins:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

    <!-- Personalizar el Footer -->
    <template id="taller_custom_footer" inherit_id="website.layout" name="Footer Personalizado Taller">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure oe_structure_solo" t-ignore="true" t-if="not no_footer" style="background-color: var(--taller-primary);">
                <section class="s_text_block pt64 pb48">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-4 mb-4 mt-3">
                                <h4 class="text-white mb-4">Taller Mecánico</h4>
                                <p class="text-white-50 lh-lg">Tu vehículo en las mejores manos. Ofrecemos calidad, confianza y garantía en todos nuestros servicios automotrices con tecnología de vanguardia.</p>
                                <div class="mt-4">
                                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle me-2" style="width:36px; height:36px; padding: 6px;"><i class="fa fa-facebook"/></a>
                                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle me-2" style="width:36px; height:36px; padding: 6px;"><i class="fa fa-instagram"/></a>
                                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width:36px; height:36px; padding: 6px;"><i class="fa fa-twitter"/></a>
                                </div>
                            </div>
                            <div class="col-lg-4 mb-4 mt-3 ps-lg-5">
                                <h4 class="text-white mb-4">Enlaces Rápidos</h4>
                                <ul class="list-unstyled">
                                    <li class="mb-3"><a href="/" class="text-white-50 text-decoration-none">Inicio</a></li>
                                    <li class="mb-3"><a href="/taller/servicios" class="text-white-50 text-decoration-none">Servicios</a></li>
                                    <li class="mb-3"><a href="/taller/contacto" class="text-white-50 text-decoration-none">Contacto</a></li>
                                    <li class="mb-3"><a href="/taller/cita" class="text-white-50 text-decoration-none">Agendar Cita</a></li>
                                </ul>
                            </div>
                            <div class="col-lg-4 mb-4 mt-3">
                                <h4 class="text-white mb-4">Contacto</h4>
                                <ul class="list-unstyled text-white-50">
                                    <li class="mb-3 d-flex align-items-center"><i class="fa fa-map-marker me-3 text-primary"/> Av. Principal 123, Ciudad</li>
                                    <li class="mb-3 d-flex align-items-center"><i class="fa fa-phone me-3 text-primary"/> +1 234 567 8900</li>
                                    <li class="mb-3 d-flex align-items-center"><i class="fa fa-envelope me-3 text-primary"/> info@tallermecanico.com</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>
                <div class="o_footer_copyright py-4" style="background: rgba(0,0,0,0.2); border-top: 1px solid rgba(255,255,255,0.05);">
                    <div class="container">
                        <div class="row align-items-center text-white-50">
                            <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                                <span>© 2026 Taller Mecánico. Todos los derechos reservados.</span>
                            </div>
                            <div class="col-md-6 text-center text-md-end">
                                <span class="small">Diseñado con <i class="fa fa-heart text-danger mx-1"/> para la excelencia automotriz.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
