<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_taller_vehiculo_tree" model="ir.ui.view">
        <field name="name">taller.vehiculo.tree</field>
        <field name="model">taller.vehiculo</field>
        <field name="arch" type="xml">
            <list>
                <field name="placa"/>
                <field name="propietario_id"/>
                <field name="marca_id"/>
                <field name="modelo_id"/>
                <field name="anio"/>
            </list>
        </field>
    </record>

    <record id="view_taller_vehiculo_kanban" model="ir.ui.view">
        <field name="name">taller.vehiculo.kanban</field>
        <field name="model">taller.vehiculo</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="placa"/>
                <field name="propietario_id"/>
                <field name="marca_id"/>
                <field name="modelo_id"/>
                <field name="foto"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('taller.vehiculo', 'foto', record.id.raw_value)" alt="Vehículo"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="placa"/></strong>
                                <div class="o_kanban_tags_section">
                                    <span class="badge rounded-pill text-bg-primary"><field name="marca_id"/> <field name="modelo_id"/></span>
                                </div>
                                <ul>
                                    <li>Propietario: <field name="propietario_id"/></li>
                                    <li>Año: <field name="anio"/></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_taller_vehiculo_form" model="ir.ui.view">
        <field name="name">taller.vehiculo.form</field>
        <field name="model">taller.vehiculo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="foto" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="placa" placeholder="Placa"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos del Propietario">
                            <field name="propietario_id" string="Propietario (Usuario Taller)"/>
                            <field name="marca_id" placeholder="Ej: Toyota" options="{'no_create': True}"/>
                            <field name="modelo_id" placeholder="Ej: Corolla" options="{'no_create': True}"/>
                            <field name="anio" placeholder="Ej: 2020"/>
                        </group>
                        <group string="Características">
                            <field name="color" widget="radio"/>
                            <field name="kilometraje"/>
                            <field name="tipo_combustible"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Historial de Mantenimientos">
                            <field name="historial_servicio_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_taller_vehiculo" model="ir.actions.act_window">
        <field name="name">Vehículos de Clientes</field>
        <field name="res_model">taller.vehiculo</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_vehiculo_action" parent="menu_taller_vehiculos" action="action_taller_vehiculo" sequence="10"/>

    <!-- Wizard: Buscar y Agregar Marca desde API NHTSA (definido primero para que la lista pueda referenciarlo) -->
    <record id="view_taller_marca_buscar_wizard_form" model="ir.ui.view">
        <field name="name">taller.marca.buscar.wizard.form</field>
        <field name="model">taller.marca.buscar.wizard</field>
        <field name="arch" type="xml">
            <form string="Buscar y Agregar Marca">
                <sheet>
                    <div class="oe_title">
                        <h1>&#128269; Buscar Marca en API NHTSA</h1>
                    </div>
                    <group>
                        <field name="termino_busqueda" placeholder="Ej: Chery, Renault, JAC..."/>
                    </group>
                    <div>
                        <button name="action_buscar" string="Buscar" type="object" class="btn btn-primary"/>
                    </div>
                    <div invisible="not mensaje">
                        <p class="text-muted"><field name="mensaje"/></p>
                    </div>
                    <field name="resultado_ids" invisible="not resultado_ids">
                        <list editable="bottom">
                            <field name="seleccionar"/>
                            <field name="name"/>
                            <field name="nhtsa_id"/>
                            <field name="ya_existe" widget="boolean" readonly="1"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_agregar_seleccionadas" string="&#10004; Agregar Seleccionadas" type="object" class="btn btn-success"
                        invisible="not resultado_ids"/>
                    <button string="Cancelar" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_taller_marca_buscar_wizard" model="ir.actions.act_window">
        <field name="name">Buscar y Agregar Marca</field>
        <field name="res_model">taller.marca.buscar.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Vista lista de Marca -->
    <record id="view_taller_marca_tree" model="ir.ui.view">
        <field name="name">taller.marca.tree</field>
        <field name="model">taller.marca</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Marca"/>
                <field name="modelos_count" string="Modelos"/>
                <field name="nhtsa_id" string="ID NHTSA" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_taller_marca_form" model="ir.ui.view">
        <field name="name">taller.marca.form</field>
        <field name="model">taller.marca</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_makes" string="Sincronizar Marcas (API)" type="object" class="oe_highlight"/>
                    <button name="action_sync_all_models" string="&#9654; Sincronizar Modelos de TODAS las Marcas" type="object" class="oe_highlight"/>
                    <button name="action_sync_models" string="Sincronizar Modelos (Esta Marca)" type="object"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="nhtsa_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Modelos">
                            <field name="modelo_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_taller_marca" model="ir.actions.act_window">
        <field name="name">Marcas de Veh&#237;culos</field>
        <field name="res_model">taller.marca</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Acciones de Servidor para el menú ⚙️ Acción -->
    <record id="action_server_sync_all_models" model="ir.actions.server">
        <field name="name">&#9654; Sincronizar Modelos (Todas las Marcas)</field>
        <field name="model_id" ref="model_taller_marca"/>
        <field name="binding_model_id" ref="model_taller_marca"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_sync_all_models()</field>
    </record>

    <!-- Marcas bajo Configuración (más lógico y accesible) -->
    <menuitem id="menu_marca_action" parent="menu_taller_configuracion" action="action_taller_marca" sequence="10"
              name="Marcas de Vehículos"/>
    <menuitem id="menu_agregar_marca_wizard" parent="menu_taller_configuracion" action="action_taller_marca_buscar_wizard"
              name="&#10133; Buscar y Agregar Marca" sequence="20"/>


</odoo>
