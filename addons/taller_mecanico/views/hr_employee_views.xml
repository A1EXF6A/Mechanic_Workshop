<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_taller" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.taller</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_ordenes_trabajo" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-wrench" 
                        groups="base.group_user">
                    <field name="orden_trabajo_count" widget="statinfo" string="Órdenes de Trabajo"/>
                </button>
            </div>
        </field>
    </record>
</odoo>
