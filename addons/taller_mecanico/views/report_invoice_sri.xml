<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_inherit_sri" inherit_id="account.report_invoice_document">
        
        <!-- Insertamos la clave de acceso debajo de la información principal de la factura -->
        <xpath expr="//div[@id='informations']" position="after">
            <t t-if="o.sri_clave_acceso">
                <div class="row mt-4 mb-4" id="sri_barcode_section">
                    <div class="col-12" style="border: 1px solid #ccc; padding: 15px; border-radius: 5px;">
                        <strong>CLAVE DE ACCESO:</strong>
                        <div style="font-family: monospace; font-size: 14px; letter-spacing: 1px; margin-top: 5px;">
                            <span t-field="o.sri_clave_acceso"/>
                        </div>
                        <div class="mt-2 text-center" style="background-color: white; padding: 10px;">
                            <div t-field="o.sri_clave_acceso" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 100, 'img_style': 'width:100%;height:80px'}"/>
                        </div>
                        <div class="text-muted mt-2" style="font-size: 11px;">
                            Estado: <strong t-esc="dict(o.fields_get(allfields=['sri_estado_autorizacion'])['sri_estado_autorizacion']['selection'])[o.sri_estado_autorizacion]"/>
                            | Fecha Autorización: <span t-field="o.sri_fecha_autorizacion" t-options='{"widget": "datetime"}'/>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
        
    </template>
</odoo>
