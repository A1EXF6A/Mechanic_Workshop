<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_sri" model="ir.ui.view">
        <field name="name">res.company.form.inherit.sri</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Facturación Electrónica SRI">
                    <group>
                        <group string="Credenciales">
                            <field name="sri_entorno"/>
                            <field name="sri_firma_p12" filename="firma_name"/>
                            <field name="sri_firma_password" password="True"/>
                        </group>
                        <group string="Datos Adicionales">
                            <field name="sri_obligado_contabilidad"/>
                            <field name="sri_resolucion_contribuyente"/>
                            <field name="sri_agente_retencion"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
