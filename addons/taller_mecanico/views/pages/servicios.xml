<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="servicios_page" name="Servicios - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_title pt48 pb24 text-center">
                    <div class="container">
                        <h2>Nuestros Servicios</h2>
                        <p class="lead">Cuidamos de tu vehículo con los mejores especialistas.</p>
                    </div>
                </section>

                <section class="s_features pt32 pb32">
                    <div class="container">
                        <div class="row">
                            <!-- Servicio 1 -->
                            <div class="col-lg-4 pt16 pb16 text-center">
                                <i class="fa fa-cogs fa-4x mb-3 text-primary"/>
                                <h3>Mantenimiento Preventivo</h3>
                                <p>Revisión general, cambio de aceite, filtros y fluidos para asegurar la vida útil de tu motor.</p>
                            </div>
                            <!-- Servicio 2 -->
                            <div class="col-lg-4 pt16 pb16 text-center">
                                <i class="fa fa-car fa-4x mb-3 text-primary"/>
                                <h3>Reparación de Frenos</h3>
                                <p>Diagnóstico, cambio de pastillas y rectificación de discos para garantizar tu seguridad.</p>
                            </div>
                            <!-- Servicio 3 -->
                            <div class="col-lg-4 pt16 pb16 text-center">
                                <i class="fa fa-laptop fa-4x mb-3 text-primary"/>
                                <h3>Diagnóstico Computarizado</h3>
                                <p>Escaneo avanzado con equipos de última generación para identificar fallas ocultas.</p>
                            </div>
                        </div>
                    </div>
                </section>
                
                <section class="pt32 pb48 text-center bg-primary text-white">
                    <div class="container">
                        <h3 class="mb-4">¿Necesitas repuestos o accesorios de calidad?</h3>
                        <p class="lead mb-4">Explora nuestro catálogo de productos y compra directamente en línea.</p>
                        <a href="/taller/productos" class="btn btn-light btn-lg shadow">
                            <i class="fa fa-shopping-bag me-2"/> Ver Catálogo de Productos
                        </a>
                    </div>
                </section>

                <section class="pt32 pb48 text-center bg-200">
                    <div class="container">
                        <h3 class="mb-4">¿Necesitas un servicio especializado?</h3>
                        <a href="/taller/contacto" class="btn btn-primary btn-lg">Contáctanos</a>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
