<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cita_confirmacion_page" name="Cita Confirmada - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-light">
                <section class="py-5 text-center mt-5">
                    <div class="container py-5">
                        <i class="fa fa-check-circle fa-5x text-success mb-4"/>
                        <h2 class="display-4 fw-bold mb-3 text-dark">¡Cita Agendada Exitosamente!</h2>
                        <p class="lead text-muted mb-5">Hemos recibido tu solicitud. Nuestro equipo técnico revisará los detalles y te contactaremos pronto para confirmar tu cita.</p>
                        <a href="/" class="btn btn-primary btn-lg shadow fw-bold px-5">Volver al Inicio</a>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
