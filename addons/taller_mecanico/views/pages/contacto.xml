<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contacto_page" name="Contacto - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5" style="background: #f8fafc;">
                    <div class="container py-4">
                        <div class="text-center mb-5">
                            <h6 class="text-primary text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 2px;">Contacto</h6>
                            <h2 class="fw-bold mb-2">Estamos aquí para ayudarte</h2>
                            <p class="text-muted" style="max-width: 500px; margin: 0 auto;">Resuelve tus dudas o agenda una cita directamente con nuestro equipo.</p>
                        </div>

                        <div class="row g-4 mb-5">
                            <div class="col-md-4">
                                <div class="card border-0 h-100 p-3 text-center" style="background: #ffffff;">
                                    <div class="card-body">
                                        <div class="bg-primary bg-opacity-10 rounded-2 d-inline-flex align-items-center justify-content-center mb-3" style="width: 44px; height: 44px;">
                                            <i class="fa fa-map-marker text-primary"/>
                                        </div>
                                        <h6 class="fw-bold mb-2">Dirección</h6>
                                        <p class="text-muted small mb-0">Av. Principal 123, Ciudad</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-0 h-100 p-3 text-center" style="background: #ffffff;">
                                    <div class="card-body">
                                        <div class="bg-primary bg-opacity-10 rounded-2 d-inline-flex align-items-center justify-content-center mb-3" style="width: 44px; height: 44px;">
                                            <i class="fa fa-phone text-primary"/>
                                        </div>
                                        <h6 class="fw-bold mb-2">Teléfono</h6>
                                        <p class="text-muted small mb-0">+1 234 567 8900</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-0 h-100 p-3 text-center" style="background: #ffffff;">
                                    <div class="card-body">
                                        <div class="bg-primary bg-opacity-10 rounded-2 d-inline-flex align-items-center justify-content-center mb-3" style="width: 44px; height: 44px;">
                                            <i class="fa fa-envelope text-primary"/>
                                        </div>
                                        <h6 class="fw-bold mb-2">Email</h6>
                                        <p class="text-muted small mb-0">contacto@tallermecanico.com</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-5 align-items-start">
                            <div class="col-lg-5">
                                <div class="card border-0" style="background: #ffffff;">
                                    <div class="card-body p-4 p-lg-5">
                                        <h4 class="fw-bold mb-1">Horarios</h4>
                                        <p class="text-muted small mb-4">Te esperamos en nuestros horarios de atención.</p>

                                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                                            <span class="text-muted small">Lunes - Viernes</span>
                                            <span class="fw-bold small">08:00 - 18:00</span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                                            <span class="text-muted small">Sábados</span>
                                            <span class="fw-bold small">09:00 - 14:00</span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center py-3">
                                            <span class="text-muted small">Domingos</span>
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-1">Cerrado</span>
                                        </div>

                                        <div class="mt-4 pt-3 border-top">
                                            <p class="text-muted small mb-2">
                                                <i class="fa fa-clock-o text-primary me-2"/>
                                                Consulta disponibilidad antes de visitarnos.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-7">
                                <div class="card border-0" style="background: #ffffff;">
                                    <div class="card-body p-4 p-lg-5">
                                        <h4 class="fw-bold mb-1">Envíanos un mensaje</h4>
                                        <p class="text-muted small mb-4">Te responderemos en menos de 24 horas.</p>

                                        <form action="#" method="get" class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Nombre</label>
                                                <input type="text" class="form-control" placeholder="Tu nombre" required="1"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Email</label>
                                                <input type="email" class="form-control" placeholder="tu@email.com" required="1"/>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Teléfono</label>
                                                <input type="tel" class="form-control" placeholder="+1 234 567 8900"/>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Mensaje</label>
                                                <textarea class="form-control" rows="4" placeholder="¿En qué podemos ayudarte?" required="1"/>
                                            </div>
                                            <div class="col-12 pt-2">
                                                <button type="button" class="btn btn-primary px-4" onclick="alert('Gracias por contactarnos. Te responderemos pronto.')">
                                                    Enviar mensaje
                                                    <i class="fa fa-send ms-2" style="font-size: 0.75rem;"/>
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
