<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="confirmacion_page" name="Confirmación - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure bg-light">
                <section class="py-5">
                    <div class="container py-5">
                        <div class="row justify-content-center">
                            <div class="col-lg-6 text-center">
                                <!-- Animación Visual de Éxito -->
                                <div class="mb-5 position-relative d-inline-block">
                                    <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 140px; height: 140px; margin: 0 auto; position: relative; z-index: 2;">
                                        <i class="fa fa-check-circle text-success" style="font-size: 4rem;"/>
                                    </div>
                                    <div class="position-absolute top-50 start-50 translate-middle bg-success bg-opacity-5 rounded-circle" style="width: 200px; height: 200px; z-index: 1;"/>
                                </div>
                                
                                <h1 class="display-4 fw-bold mb-3 text-primary">¡Orden Confirmada!</h1>
                                <p class="lead text-muted mb-5 px-lg-5">Gracias por confiar en el Taller Mecánico. Tu pedido ha sido procesado y el stock ha sido reservado exitosamente.</p>
                                
                                <!-- Card de Resumen Estilo Ticket -->
                                <div class="card border-0 shadow-lg mb-5 text-start overflow-hidden" style="border-radius: 20px !important;">
                                    <div class="bg-primary p-4 text-white">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <h5 class="mb-0 fw-bold">Resumen de la Transacción</h5>
                                            <span class="badge bg-white text-primary rounded-pill px-3 py-2 fw-bold" style="font-size: 0.7rem;">FACTURADO</span>
                                        </div>
                                    </div>
                                    <div class="card-body p-4 p-md-5">
                                        <div class="d-flex justify-content-between mb-4 pb-2 border-bottom">
                                            <span class="text-muted small text-uppercase fw-bold">Número de Orden</span>
                                            <span class="fw-bold h5 mb-0" t-field="order.name"/>
                                        </div>
                                        <div class="d-flex justify-content-between mb-4 pb-2 border-bottom">
                                            <span class="text-muted small text-uppercase fw-bold">Fecha y Hora</span>
                                            <span class="fw-bold" t-field="order.date_order" t-options="{'widget': 'datetime'}"/>
                                        </div>
                                        <div class="d-flex justify-content-between mb-4 pb-2 border-bottom">
                                            <span class="text-muted small text-uppercase fw-bold">Total del Pedido</span>
                                            <span class="fw-bold h5 mb-0 text-primary" t-field="order.amount_total" t-options="{'widget': 'monetary', 'display_currency': website.company_id.currency_id}"/>
                                        </div>
                                        <div class="d-flex justify-content-between">
                                            <span class="text-muted small text-uppercase fw-bold">Método</span>
                                            <span class="fw-bold">Retiro / Instalación en Taller</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Info Adicional -->
                                <div class="p-4 bg-white rounded-4 border-0 shadow-sm mb-5 d-flex align-items-center gap-4" style="border-radius: 15px !important;">
                                    <div class="text-primary">
                                        <i class="fa fa-info-circle fa-3x opacity-50"/>
                                    </div>
                                    <div class="text-start">
                                        <h6 class="fw-bold mb-1">Manejo de Inventario Automático</h6>
                                        <p class="text-muted small mb-0">Hemos actualizado nuestras existencias para asegurar que tus repuestos estén listos para ti.</p>
                                    </div>
                                </div>
                                
                                <!-- Acciones Finales -->
                                <div class="d-grid d-md-flex justify-content-md-center gap-3">
                                    <a href="/" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-lg fw-bold">VOLVER AL INICIO</a>
                                    <a href="/taller/productos" class="btn btn-outline-primary btn-lg px-5 py-3 rounded-pill fw-bold">SEGUIR COMPRANDO</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
