<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="productos_page" name="Productos - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="s_title pt48 pb24 text-center">
                    <div class="container">
                        <h2>Nuestros Productos y Repuestos</h2>
                        <p class="lead">Calidad garantizada para tu vehículo.</p>
                    </div>
                </section>
                <section class="s_dynamic_snippet_products pt32 pb32">
                    <div class="container">
                        <div class="row">
                            <t t-foreach="products" t-as="product">
                                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                                    <div class="card h-100 shadow-sm border-0 transition-hover">
                                        <img t-att-src="website.image_url(product, 'image_1920')" class="card-img-top p-3" t-att-alt="product.name" style="height: 200px; object-fit: contain;"/>
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title text-truncate" t-field="product.name"/>
                                            <p class="card-text text-primary fw-bold" t-field="product.list_price" t-options="{'widget': 'monetary', 'display_currency': website.company_id.currency_id}"/>
                                            <div class="mt-auto">
                                                <button class="btn btn-primary w-100 js_add_to_cart" t-att-data-product-id="product.product_variant_id.id">
                                                    <i class="fa fa-shopping-cart me-2"/> Agregar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
