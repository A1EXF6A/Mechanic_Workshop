<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sobrescribir la página de inicio por defecto de Odoo -->
    <template id="home_page" inherit_id="website.homepage" name="Inicio - Taller Mecánico">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">
                <!-- Banner -->
                <section class="s_cover parallax s_parallax_is_mutted bg-black-50 pt96 pb96" data-scroll-background-ratio="1">
                    <span class="s_parallax_bg oe_img_bg" style="background-image: url('/web/image/website.s_cover_default_image'); background-position: 50% 0;"/>
                    <div class="o_we_bg_filter bg-black-50"/>
                    <div class="container s_allow_columns">
                        <h1 style="text-align: center; color: white;">Tu Taller Mecánico de Confianza</h1>
                        <p class="lead" style="text-align: center; color: white;">Brindamos servicios de calidad con personal altamente capacitado para tu vehículo.</p>
                        <div style="text-align: center;">
                            <a href="/taller/cita" class="btn btn-primary btn-lg mt-3">Agendar una Cita Ahora</a>
                        </div>
                    </div>
                </section>
                
                <!-- About Us -->
                <section class="s_text_image pt32 pb32">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6 pt16 pb16">
                                <h2>Nuestra Experiencia</h2>
                                <p>Con más de 15 años de experiencia, garantizamos soluciones rápidas, seguras y al mejor precio del mercado. Utilizamos tecnología de punta para el diagnóstico automotriz.</p>
                                <a href="/taller/servicios" class="btn btn-outline-primary mt-2">Conoce nuestros servicios</a>
                            </div>
                            <div class="col-lg-6 pt16 pb16">
                                <img src="/web/image/website.s_text_image_default_image" class="img img-fluid mx-auto rounded" alt="Taller"/>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>
    </template>
</odoo>
