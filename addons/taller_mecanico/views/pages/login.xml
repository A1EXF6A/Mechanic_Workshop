<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login_page" name="Login - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="taller-auth min-vh-100 d-flex align-items-center py-5">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-5 col-md-7">
                                <div class="taller-auth-card card p-2">
                                    <div class="card-body p-4 p-lg-5">
                                        <div class="text-center mb-2">
                                            <div class="bg-primary bg-opacity-10 rounded-2 d-inline-flex align-items-center justify-content-center mb-4" style="width: 48px; height: 48px;">
                                                <i class="fa fa-user text-primary" style="font-size: 1.25rem;"/>
                                            </div>
                                            <h2 class="fw-bold mb-1">Bienvenido</h2>
                                            <p class="text-muted small mb-0">Accede con tu cuenta del taller</p>
                                        </div>

                                        <t t-if="login_error">
                                            <div class="alert alert-danger d-flex align-items-center gap-2 mt-4 mb-0" role="alert">
                                                <i class="fa fa-exclamation-circle flex-shrink-0"/>
                                                <span>Correo o contraseña incorrectos.</span>
                                            </div>
                                        </t>

                                        <form action="/taller/login/submit" method="post" class="mt-4">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="redirect" t-att-value="redirect or '/'"/>

                                            <div class="mb-3">
                                                <label class="form-label">Correo electrónico</label>
                                                <input type="email" name="email" class="form-control" required="1" placeholder="tu@email.com"/>
                                            </div>

                                            <div class="mb-4">
                                                <label class="form-label">Contraseña</label>
                                                <input type="password" name="password" class="form-control" required="1" placeholder="••••••••"/>
                                            </div>

                                            <button type="submit" class="btn btn-primary w-100 py-2">
                                                Ingresar
                                                <i class="fa fa-arrow-right" style="font-size: 0.75rem;"/>
                                            </button>
                                        </form>

                                        <div class="text-center mt-4 pt-3 border-top">
                                            <p class="text-muted small mb-3">¿No tienes cuenta?</p>
                                            <a href="/taller/registro" class="btn btn-outline-primary w-100 py-2">
                                                Crear cuenta
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
