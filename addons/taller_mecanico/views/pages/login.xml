<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login_page" name="Login - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-light">
                <section class="py-5 taller-auth">
                    <div class="container py-5">
                        <div class="row justify-content-center">
                            <div class="col-lg-6">
                                <div class="card border-0 shadow-lg taller-auth-card">
                                    <div class="card-body p-4 p-lg-5">
                                        <h2 class="fw-bold mb-2 taller-auth-title">Ingresar</h2>
                                        <p class="text-muted mb-4 taller-auth-subtitle">Accede con tu cuenta del sitio.</p>
                                        <t t-if="login_error">
                                            <div class="alert alert-danger" role="alert">
                                                Correo o password incorrectos.
                                            </div>
                                        </t>
                                        <form action="/taller/login/submit" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <div class="mb-3">
                                                <label class="form-label fw-bold">Correo</label>
                                                <input type="email" name="email" class="form-control form-control-lg" required="1" placeholder="tu@email.com"/>
                                            </div>
                                            <div class="mb-4">
                                                <label class="form-label fw-bold">Password</label>
                                                <input type="password" name="password" class="form-control form-control-lg" required="1" placeholder="********"/>
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-lg w-100">Ingresar</button>
                                        </form>
                                        <div class="d-grid gap-2 mt-4">
                                            <a href="/taller/registro" class="btn btn-outline-primary btn-lg">Registrarse</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
