<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="registro_confirmacion_page" name="Registro Confirmado - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="taller-auth min-vh-100 d-flex align-items-center py-5">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-6 col-md-8">
                                <div class="taller-auth-card card p-2">
                                    <div class="card-body p-4 p-lg-5 text-center">
                                        <div class="bg-success bg-opacity-10 rounded-2 d-inline-flex align-items-center justify-content-center mb-4" style="width: 56px; height: 56px;">
                                            <i class="fa fa-check-circle text-success" style="font-size: 1.5rem;"/>
                                        </div>

                                        <h2 class="fw-bold mb-2">Registro completado</h2>
                                        <p class="text-muted small mb-4">Tus datos se guardaron correctamente.</p>

                                        <div class="d-grid gap-2 mt-4 pt-3 border-top">
                                            <a href="/taller/login" class="btn btn-primary py-2">
                                                Iniciar sesión
                                                <i class="fa fa-arrow-right ms-2" style="font-size: 0.75rem;"/>
                                            </a>
                                            <a href="/" class="btn btn-outline-primary py-2">Volver al inicio</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
