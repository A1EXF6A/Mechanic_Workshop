<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="registro_page" name="Registro - Taller Mecánico">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-light">
                <section class="py-5 taller-auth">
                    <div class="container py-5">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-lg taller-auth-card">
                                    <div class="card-body p-4 p-lg-5">
                                        <h2 class="fw-bold mb-2 taller-auth-title">Registro de Usuario</h2>
                                        <p class="text-muted mb-4 taller-auth-subtitle">Crea tu cuenta para gestionar tus servicios.</p>
                                        <form action="/taller/registro/submit" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Cedula</label>
                                                    <input type="text" name="cedula" class="form-control form-control-lg" required="1" placeholder="0102030405"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Edad</label>
                                                    <input type="number" name="edad" class="form-control form-control-lg" min="18" required="1" placeholder="18"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Nombre</label>
                                                    <input type="text" name="nombre" class="form-control form-control-lg" required="1" placeholder="Juan"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Apellido</label>
                                                    <input type="text" name="apellido" class="form-control form-control-lg" required="1" placeholder="Perez"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Direccion de correo</label>
                                                    <input type="email" name="email" class="form-control form-control-lg" required="1" placeholder="tu@email.com"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Celular</label>
                                                    <input type="text" name="celular" class="form-control form-control-lg" required="1" placeholder="0987654321"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Direccion donde vive</label>
                                                    <input type="text" name="direccion" class="form-control form-control-lg" required="1" placeholder="Av. Principal 123"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Password</label>
                                                    <input type="password" name="password" class="form-control form-control-lg" required="1" placeholder="********"/>
                                                </div>
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-lg w-100 mt-4">Crear Cuenta</button>
                                        </form>
                                        <p class="text-muted small mt-4 mb-0">Ya tienes cuenta? <a href="/taller/login">Ingresa</a></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
