<odoo>

    <!-- FORM -->
    <record id="view_tipo_cita_form" model="ir.ui.view">
        <field name="name">taller.tipo.cita.form</field>
        <field name="model">taller.tipo.cita</field>
        <field name="arch" type="xml">
            <form string="Tipo de Cita">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST -->
    <record id="view_tipo_cita_list" model="ir.ui.view">
        <field name="name">taller.tipo.cita.list</field>
        <field name="model">taller.tipo.cita</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="descripcion"/>
            </list>
        </field>
    </record>

    <!-- ACCIÓN -->
    <record id="action_tipo_cita" model="ir.actions.act_window">
        <field name="name">Tipos de Cita</field>
        <field name="res_model">taller.tipo.cita</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 👇 MENÚ AQUÍ (IMPORTANTE) -->
    <menuitem id="menu_tipo_citas"
              name="Tipos de Citas"
              parent="menu_taller_root"
              action="action_tipo_cita"/>

</odoo>