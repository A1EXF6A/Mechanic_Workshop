<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_math_operation_tree" model="ir.ui.view">
        <field name="name">math.operation.tree</field>
        <field name="model">math.operation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="operand_1"/>
                <field name="operand_2"/>
                <field name="operation_type"/>
                <field name="result"/>
                <field name="operation_date"/>
                <field name="user_id"/>
                <field name="active"/>
                <field name="notes"/> <!-- Añadido para mostrar el campo notes -->
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_math_operation_form" model="ir.ui.view">
        <field name="name">math.operation.form</field>
        <field name="model">math.operation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="operand_1"/>
                        <field name="operand_2"/>
                        <field name="operation_type"/>
                        <field name="result" readonly="1"/>
                        <field name="operation_date"/>
                        <field name="user_id" readonly="1"/>
                        <field name="notes"/>
                        <field name="id" readonly="1"/> <!-- Añadido para mostrar el ID de la operación -->
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_math_operation" model="ir.actions.act_window">
        <field name="name">Operaciones Matemáticas</field>
        <field name="res_model">math.operation</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menús -->
    <menuitem 
        id="menu_math_root"
        name="Matemáticas"
        sequence="10"/>

    <menuitem 
        id="menu_math_operation"
        name="Operaciones"
        parent="menu_math_root"
        action="action_math_operation"
        sequence="1"/>

</odoo>