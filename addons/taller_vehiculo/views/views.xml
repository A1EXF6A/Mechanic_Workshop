<odoo>

    <record id="taller_vehiculo_list" model="ir.ui.view">
        <field name="name">taller.vehiculo.list</field>
        <field name="model">taller.vehiculo</field>
        <field name="arch" type="xml">
            <list>
                <field name="matricula"/>
                <field name="marca"/>
                <field name="modelo"/>
                <field name="anio"/>
                <field name="color"/>
                <field name="usuario_id"/>
            </list>
        </field>
    </record>

    <record id="taller_vehiculo_form" model="ir.ui.view">
        <field name="name">taller.vehiculo.form</field>
        <field name="model">taller.vehiculo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="matricula"/>
                            <field name="marca"/>
                            <field name="modelo"/>
                            <field name="anio"/>
                        </group>
                        <group>
                            <field name="color"/>
                            <field name="usuario_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="historial" string="Historial">
                            <field name="historial_ids">
                                <list>
                                    <field name="fecha"/>
                                    <field name="tipo"/>
                                    <field name="descripcion"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="taller_historial_list" model="ir.ui.view">
        <field name="name">taller.historial.list</field>
        <field name="model">taller.historial</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehiculo_id"/>
                <field name="fecha"/>
                <field name="tipo"/>
                <field name="descripcion"/>
            </list>
        </field>
    </record>

    <record id="taller_historial_form" model="ir.ui.view">
        <field name="name">taller.historial.form</field>
        <field name="model">taller.historial</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="vehiculo_id"/>
                            <field name="fecha"/>
                            <field name="tipo"/>
                        </group>
                        <group>
                            <field name="descripcion"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="taller_vehiculo_action" model="ir.actions.act_window">
        <field name="name">Vehículos</field>
        <field name="res_model">taller.vehiculo</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="taller_historial_action" model="ir.actions.act_window">
        <field name="name">Historial</field>
        <field name="res_model">taller.historial</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="taller_vehiculo_menu_root" name="Vehículos Taller"/>
    <menuitem id="taller_vehiculo_menu" name="Vehículos" parent="taller_vehiculo_menu_root" action="taller_vehiculo_action"/>
    <menuitem id="taller_historial_menu" name="Historial" parent="taller_vehiculo_menu_root" action="taller_historial_action"/>

</odoo>
